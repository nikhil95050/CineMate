# --- Core bot configuration ---


# Telegram
TELEGRAM_BOT_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Redis 
REDIS_API_KEY=
REDIS_REST_URL=
REDIS_URL=

# Perplexity
PERPLEXITY_API_KEY=

# OMDB
OMDB_API_KEY=

# WatchMode
WATCHMODE_API_KEY=

# Optional Feature Flags (default: true)
ENABLE_PERPLEXITY=false
ENABLE_TRAILERS=true
ENABLE_EXPLANATIONS=true

# Admin
ADMIN_CHAT_IDS=1878846631

# Name of the Redis queue for background jobs.
CINEMATE_QUEUE_NAME=cinemate_intent_jobs

# For local dev / tests: run jobs inline instead of via RQ worker.
# Set to 1/true/yes to avoid needing Redis/RQ in development.
 CINEMATE_INLINE_JOBS=0


